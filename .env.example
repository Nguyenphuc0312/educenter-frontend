
# ── API Base URL ──────────────────────────────────────────────
# Copy file này thành .env rồi sửa giá trị cho đúng với máy bạn.
# File .env KHÔNG được commit lên Git.

# Mặc định: chạy tất cả service trên máy mình
VITE_API_BASE_URL=http://localhost:5264

# Từng service riêng (bỏ comment và sửa IP/port nếu cần):
VITE_COURSE_API_URL=http://localhost:5264/api
# VITE_STUDENT_API_URL=http://localhost:5002/api
# VITE_PAYMENT_API_URL=http://localhost:5003/api

# ── Demo trên nhiều máy LAN ──────────────────────────────────
# Đổi localhost thành IP LAN của máy chạy service tương ứng:
# VITE_COURSE_API_URL=http://192.168.29.xxx:5264/api
# VITE_STUDENT_API_URL=http://192.168.29.yyy:5002/api
# VITE_PAYMENT_API_URL=http://192.168.29.zzz:5003/api
